# ==============================================================================
# Vedrix AI Interview System — Backend Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env
#
# All variables are read by pydantic-settings from the Settings class
# in app/core/config.py. Values shown here are defaults unless noted.
# ==============================================================================

# ── General ──────────────────────────────────────────────────────────────────
# API route prefix (no trailing slash)
API_V1_STR="/api/v1"
# Display name used in emails and UI
PROJECT_NAME="Vedrix"
# Semantic version string exposed via /api/v1/health
APP_VERSION="1.0.0"

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production — used to sign JWTs. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="change-me-in-production-use-env-file"
# JWT algorithm (HS256 is the default; change only if you know what you're doing)
ALGORITHM="HS256"
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7
# REQUIRED in production — CSRF protection secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SECRET="change-me-csrf-secret-in-production"

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev default) — must use aiosqlite driver for async
DATABASE_URL="sqlite+aiosqlite:///./vedrix.db"
# PostgreSQL example (production):
# DATABASE_URL="postgresql+asyncpg://user:password@host:5432/vedrix"
# PostgreSQL SSL mode: "disable", "require", "verify-full"
DB_SSL_MODE="require"

# ── AI API Keys ──────────────────────────────────────────────────────────────
# At least one key is needed for interviews to function.
# Groq — low-latency inference & Whisper transcription
GROQ_API_KEY=""
# NVIDIA NIM — deep analysis models
NVIDIA_API_KEY=""
# OpenRouter — unified multi-model gateway
OPENROUTER_API_KEY=""
# OpenAI — GPT-4 / TTS (optional)
OPENAI_API_KEY=""
# ApiFree — free-tier fallback
APIFREE_API_KEY=""

# ── AI Base URLs ─────────────────────────────────────────────────────────────
# Override only if you use a self-hosted proxy or mirror.
GROQ_BASE_URL="https://api.groq.com/openai/v1"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
APIFREE_BASE_URL="https://apifreellm.com/api/v1"

# ── Email ────────────────────────────────────────────────────────────────────
# Backend for sending emails: 'console' (dev, prints to stdout), 'smtp', or 'sendgrid'
EMAIL_BACKEND="console"
# SendGrid API key (required when EMAIL_BACKEND=sendgrid)
SENDGRID_API_KEY=""
# SMTP settings (required when EMAIL_BACKEND=smtp)
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT=587
MAIL_USERNAME=""
MAIL_PASSWORD=""
# Display name in outbound emails
MAIL_FROM_NAME="Vedrix AI"
# Frontend URL used in email links (magic links, invitations, etc.)
FRONTEND_URL="http://localhost:5173"

# ── Judge0 Code Execution ───────────────────────────────────────────────────
# Remote code execution sandbox for coding interviews
JUDGE0_URL="https://judge0-ce.p.rapidapi.com"
JUDGE0_API_KEY=""

# ── Supabase (Optional) ─────────────────────────────────────────────────────
# When configured, data is mirrored to a Supabase Postgres instance.
SUPABASE_URL=""
# Use the publishable/anon key or service key
SUPABASE_KEY=""

# ── Redis ────────────────────────────────────────────────────────────────────
# Used for caching AI responses and rate limiting. Optional in dev.
REDIS_URL="redis://localhost:6379/0"

# ── Social Login (OAuth2) ───────────────────────────────────────────────────
# Google OAuth2
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub OAuth2
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# LinkedIn OAuth2
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Example: "http://localhost:5173,https://vedrix.io"
# Leave empty to use default permissive development origins.
ALLOWED_ORIGINS=""

# ── Environment ──────────────────────────────────────────────────────────────
# "development" or "production" — controls debug logging, error details, etc.
ENVIRONMENT="development"
