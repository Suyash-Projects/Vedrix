# 🤖 Vedrix: Environment Configuration Example

# ── PROJECT SETTINGS ──────────────────────────────────────────────────────────
PROJECT_NAME=Vedrix
API_V1_STR=/api/v1
FRONTEND_URL=http://localhost:5173

# ── SECURITY (Change these in production!) ───────────────────────────────────
SECRET_KEY=generate-a-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Use 'sqlite+aiosqlite:///./vedrix.db' for local development
DATABASE_URL=sqlite+aiosqlite:///./vedrix.db

# ── AI API KEYS & PROVIDERS ───────────────────────────────────────────────────
# Vedrix uses OpenRouter as the primary gateway and Groq/NVIDIA for speed.
GROQ_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
APIFREE_API_KEY=

# ── EMAIL SETTINGS (SMTP) ─────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME="Vedrix AI"

# ── EXTERNAL SERVICES ─────────────────────────────────────────────────────────
# Judge0 for real-time code execution
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=

# Supabase (Optional: for mirroring data to a cloud Postgres instance)
SUPABASE_URL=
SUPABASE_KEY=
